  // ── OSM tile mini-map helper ──
  function tileBlock(lat,lng){
    if(!lat||!lng) return '';
    const z=14,n=1<<z;
    const xf=(lng+180)/360*n,latr=lat*Math.PI/180;
    const yf=(1-Math.log(Math.tan(latr)+1/Math.cos(latr))/Math.PI)/2*n;
    const xt=Math.floor(xf),yt=Math.floor(yf);
    const L0=Math.round(110-(xf-xt)*256),T0=Math.round(43-(yf-yt)*256);
    const u=(dx,dy)=>`https://tile.openstreetmap.org/${z}/${xt+dx}/${yt+dy}.png`;
    const im=(dx,dy,l,t)=>`<img src="${u(dx,dy)}" width="256" height="256" style="left:${l}px;top:${t}px;" loading="lazy" crossorigin="anonymous">`;
    const nR=L0+256<220,nL=L0>0,nT=T0>0,nB=T0+256<90;
    let t=im(0,0,L0,T0);
    if(nR)t+=im(1,0,L0+256,T0);   if(nL)t+=im(-1,0,L0-256,T0);
    if(nT)t+=im(0,-1,L0,T0-256);  if(nB)t+=im(0,1,L0,T0+256);
    if(nR&&nT)t+=im(1,-1,L0+256,T0-256); if(nL&&nT)t+=im(-1,-1,L0-256,T0-256);
    if(nR&&nB)t+=im(1,1,L0+256,T0+256);  if(nL&&nB)t+=im(-1,1,L0-256,T0+256);
    return `<div class="rc-map">${t}<div class="rc-map-fade"></div><div class="rc-map-pin">📍</div></div>`;
  }

