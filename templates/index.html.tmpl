  };
  function wmoByTime(code,hour){
    const[em,desc]=WMO[code]||['🌡️',''];
    if(code===0||code===1){
      if(hour<6||hour>=22) return['🌙',desc];
      if(hour<9) return[code===0?'🌅':'🌤️',desc];
