function matchVisited(worldName, worldCont){
  const wl=worldName.toLowerCase();
  function continentOk(vCountry){
    // If we know the visited city's country continent and the world city's continent, ensure match
    if(!worldCont||!vCountry) return true;
    const vc=CTRY_CONT[vCountry];
    return !vc || vc===worldCont;
  }
  if(visitedCityMap[wl]){
    const [vName,vCount,vCountry]=visitedCityMap[wl];
    if(continentOk(vCountry)) return [vName,vCount];
  }
  for(const a of (CITY_ALIASES[worldName]||[])){
    const v=visitedCityMap[a.toLowerCase()];
    if(v){
      const [vName,vCount,vCountry]=v;
      if(continentOk(vCountry)) return [vName,vCount];
    }
  }
  return null;
}

// ── City tabs ─────────────────────────────────────────────────────────────────
function switchCityTab(tab, el){
  ['checkins','country','world'].forEach(t=>{
    document.getElementById('paneCityc'.replace('c','')+t[0].toUpperCase()+t.slice(1)).style.display='none';
  });
  document.getElementById('paneCityCheckins').style.display='none';
  document.getElementById('paneCityCountry').style.display='none';
  document.getElementById('paneCityWorld').style.display='none';
  document.getElementById('paneCity'+tab[0].toUpperCase()+tab.slice(1)).style.display='block';
  document.querySelectorAll('#tabCityCheckins,#tabCityCountry,#tabCityWorld').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
  if(tab==='country' && !document.getElementById('byCountryList').innerHTML) buildByCountry('cities');
  if(tab==='world' && !document.getElementById('worldCitiesList').innerHTML) buildWorldCities('ALL');
}

// ── By-country view ──────────────────────────────────────────────────────────
let _byCountrySort='cities';
function sortByCountry(mode, el){
  _byCountrySort=mode;
  document.querySelectorAll('.sort-btn[id^="btnSort"]').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  buildByCountry(mode);
}

function buildByCountry(sort){
  const countryTotals={};
  S.countries.forEach(([c,n])=>{ countryTotals[c]=n; });
  const byCountry={};
  S.cities.forEach(([name,count,country])=>{
    if(!country) return;
    if(!byCountry[country]) byCountry[country]={cities:[],total:0};
    byCountry[country].cities.push([name,count]);
    byCountry[country].total+=count;
  });
  let countries=Object.entries(byCountry);
  if(sort==='alpha') countries.sort((a,b)=>a[0].localeCompare(b[0]));
  else if(sort==='checkins') countries.sort((a,b)=>(countryTotals[b[0]]||b[1].total)-(countryTotals[a[0]]||a[1].total));
  else countries.sort((a,b)=>b[1].cities.length-a[1].cities.length);

  const container=document.getElementById('byCountryList');
  container.innerHTML=countries.map(([country,data])=>{
    const f=flagHtml(country,'1em');
    const cityRows=data.cities.map(([city,cnt],i)=>
      `<div class="country-city-row" data-name="${esc(city).toLowerCase()} ${country.toLowerCase()}">
        <span class="country-city-rank">${i+1}</span>
        <span class="country-city-name">${esc(city)}</span>
        <span class="country-city-count">${cnt.toLocaleString()}</span>
      </div>`).join('');
    return `<div class="country-group" data-country="${esc(country).toLowerCase()}">
      <div class="country-group-header">
        <span class="country-group-name">${f} ${esc(country)}</span>
        <span class="country-group-meta">${data.cities.length} cities · ${(countryTotals[country]||data.total).toLocaleString()}</span>
      </div>
      <div class="country-city-list">${cityRows}</div>
    </div>`;
  }).join('');
}

function filterByCountry(q){
  const ql=q.toLowerCase();
  document.querySelectorAll('#byCountryList .country-group').forEach(g=>{
    const countryName=g.dataset.country||'';
    const countryMatch=countryName.includes(ql);
    let anyCity=false;
    g.querySelectorAll('.country-city-row').forEach(r=>{
      const match=countryMatch||r.dataset.name.includes(ql);
      r.classList.toggle('hidden',q.length>0&&!match);
      if(match) anyCity=true;
    });
    g.classList.toggle('hidden',q.length>0&&!countryMatch&&!anyCity);
  });
}

// ── World cities view ────────────────────────────────────────────────────────
let _worldContinent='ALL';
const CONT_NAMES={AS:'Asia',EU:'Europe',NA:'North America',SA:'South America',AF:'Africa',OC:'Oceania'};

function buildWorldCities(continent){
  _worldContinent=continent;
  const visited=Object.keys(visitedCityMap).length;
  let cities=WORLD_CITIES_100K;
  if(continent!=='ALL') cities=cities.filter(c=>c[4]===continent);

  // Sort by population desc
  cities=[...cities].sort((a,b)=>b[3]-a[3]);

  let html='';
  let visitedCount=0, totalCount=cities.length;

  cities.forEach((c,i)=>{
    const [name,lat,lng,pop,cont]=c;
    const vm=matchVisited(name,cont);
    const isVisited=!!vm;
    if(isVisited) visitedCount++;
    const popStr=pop>=1?pop.toFixed(1)+'M':(pop*1000).toFixed(0)+'K';
    const contLabel=continent==='ALL'?` <span style="font-size:.55rem;color:var(--muted);opacity:.5;margin-left:5px">${CONT_NAMES[cont]||cont}</span>`:'' ;
    const displayName=isVisited?vm[0]:name;
    html+=`<div class="world-city-row${isVisited?' visited':''}" data-name="${displayName.toLowerCase()}" data-cont="${cont}">
      <span class="world-city-rank">${i+1}</span>
      <span class="world-city-name">${esc(displayName)}${isVisited?' ✓':''} ${contLabel}</span>
      <span class="world-city-pop">${popStr}</span>
      <span class="world-city-checkins">${isVisited?vm[1].toLocaleString():''}</span>
    </div>`;
  });

  document.getElementById('worldCitiesList').innerHTML=html;
  document.getElementById('worldVisitedCount').textContent=
    visitedCount+' of '+totalCount+' cities visited (>100k pop)';
}

function filterWorldContinent(cont, el){
  document.querySelectorAll('.sort-btn[id^="btnWld"]').forEach(b=>b.classList.remove('active'));
  el.classList.add('active');
  buildWorldCities(cont);
}

function filterWorldCities(q){
  const ql=q.toLowerCase();
  document.querySelectorAll('#worldCitiesList .world-city-row').forEach(r=>{
    r.classList.toggle('hidden',q.length>0&&!r.dataset.name.includes(ql));
  });
}

// ── City dot map (one dot = one city, sized by world population) ──────────────
let cityMapInst=null;
function buildCityMap(){
  if(cityMapInst) return;
  cityMapInst=L.map('cityMap',{preferCanvas:true,zoomControl:false,attributionControl:false}).setView([25,20],2);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png',{
    attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:18}).addTo(cityMapInst);

  // Draw all visited cities with ≥5 check-ins using S.city_centroids for coords
  const centroids=S.city_centroids||{};
  cityDotLayer=L.layerGroup();

  // Build population lookup from WORLD_CITIES for tooltip enrichment
  const worldPopMap={};
  WORLD_CITIES.forEach(([n,,,pop])=>{ worldPopMap[n.toLowerCase()]=pop; });

  S.cities.forEach(([name,count])=>{
    if(count<5) return;
    const coords=centroids[name];
    if(!coords) return;
    const pop=worldPopMap[name.toLowerCase()];
    const popStr=pop?(pop>=1?pop.toFixed(1)+'M':(pop*1000).toFixed(0)+'K'):'';
    const tooltip=popStr?`${name} (${popStr}) · ${count.toLocaleString()} check-ins`
                        :`${name} · ${count.toLocaleString()} check-ins`;
    L.circleMarker([coords[0],coords[1]],{radius:5,color:'#4ec9b0',fillColor:'#4ec9b0',fillOpacity:0.8,weight:1})
      .bindTooltip(tooltip,{direction:'top',opacity:0.9}).addTo(cityDotLayer);
  });
  cityDotLayer.addTo(cityMapInst);
}

// ── City pane initialisation ─────────────────────────────────────────────────
(function(){
  // panels are shown/hidden by switchCityTab; default is checkins so nothing needed
  // Patch switchCityTab for correct pane IDs
  window.switchCityTab=function(tab,el){
    document.getElementById('paneCityCheckins').style.display=tab==='checkins'?'':'none';
    document.getElementById('paneCityCountry').style.display=tab==='country'?'':'none';
    document.getElementById('paneCityWorld').style.display=tab==='world'?'':'none';
    document.querySelectorAll('#tabCityCheckins,#tabCityCountry,#tabCityWorld').forEach(t=>t.classList.remove('active'));
    el.classList.add('active');
    if(tab==='country' && !document.getElementById('byCountryList').innerHTML) buildByCountry(_byCountrySort);
    if(tab==='world' && !document.getElementById('worldCitiesList').innerHTML) buildWorldCities('ALL');
  };
})();
</script>
