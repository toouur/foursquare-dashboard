function catIcon(cat){
  const entry=CAT_ICON[cat||''];
  if(!entry) return{em:'📍',bg:'#4a5270'};
  return{em:entry[0],bg:entry[1]};
}

// ── Map ──────────────────────────────────────────────────────────────────────
const map=L.map('map',{preferCanvas:true}).setView([30,15],2);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);

const markers={};
let selMarker=null;
ALL.forEach((t,i)=>{
  if(t.lat==null||t.lng==null)return;
  const{em,bg}=catIcon(t.category||'');
  const m=L.circleMarker([t.lat,t.lng],{radius:6,fillColor:bg,fillOpacity:.75,color:bg,weight:1}).addTo(map);
  const tipPreview=esc((t.text||'').slice(0,90))+(t.text&&t.text.length>90?'…':'');
  m.bindPopup(`<b>${esc(t.venue||'')}</b><br><span style="font-size:.75rem;color:#9ca3af;">${esc(t.city||'')}${t.country?', '+esc(t.nc||t.country):''}</span><br><br><i style="font-size:.78rem;">"${tipPreview}"</i>`,{maxWidth:220});
  markers[i]=m;
});

// ── Tabs ─────────────────────────────────────────────────────────────────────
let selCountry='', selCity='';

function buildCtryTabs(){
  const total=ALL.length;
  let html=`<button class="tab-btn ${!selCountry?'act':''}" onclick="setCountry('')">All <span class="tab-count">${total}</span></button>`;
  for(const[c,d]of Object.entries(TABS_DATA)){
    const f=flagHtml(c);
    html+=`<button class="tab-btn ${selCountry===c?'act':''}" onclick='setCountry(${JSON.stringify(c)})'>${f}${esc(c)} <span class="tab-count">${d.total}</span></button>`;
  }
  document.getElementById('ctryTabs').innerHTML=html;
}

function scrollTabs(id,dx){document.getElementById(id).scrollBy({left:dx,behavior:'smooth'});}

function buildCityTabs(){
  const row=document.getElementById('cityTabs');
  const wrap=document.getElementById('cityWrap');
  if(!selCountry){wrap.classList.remove('vis');return;}
  const d=TABS_DATA[selCountry];
  if(!d){wrap.classList.remove('vis');return;}
  wrap.classList.add('vis');
  let html=`<button class="tab-btn ${!selCity?'act':''}" onclick="setCity('')">All cities <span class="tab-count">${d.total}</span></button>`;
  for(const[c,n]of d.cities){
    if(!c)continue;
    html+=`<button class="tab-btn ${selCity===c?'act':''}" onclick='setCity(${JSON.stringify(c)})'>${esc(c)} <span class="tab-count">${n}</span></button>`;
  }
  row.innerHTML=html;
}

function setCountry(c){selCountry=c;selCity='';buildCtryTabs();buildCityTabs();render();}
function setCity(c){selCity=c;buildCityTabs();render();}

// ── Filter & sort ────────────────────────────────────────────────────────────
let sortMode='date', query='';

function getFiltered(){
  const q=query.toLowerCase();
  return ALL.map((_,i)=>i).filter(i=>{
    const t=ALL[i];
    if(selCountry && t.nc!==selCountry) return false;
    if(selCity && t.nci!==selCity) return false;
    if(!q) return true;
    return (t.text||'').toLowerCase().includes(q)||(t.venue||'').toLowerCase().includes(q)||(t.city||'').toLowerCase().includes(q)||(t.country||'').toLowerCase().includes(q)||(t.category||'').toLowerCase().includes(q);
  });
}

function render(){
  let idx=getFiltered();
  if(sortMode==='agree')idx.sort((a,b)=>(ALL[b].agree_count||0)-(ALL[a].agree_count||0));
  document.getElementById('badge').textContent=idx.length+' / '+ALL.length+' tips';
  document.getElementById('feedScroll').innerHTML=idx.map(i=>{
    const t=ALL[i];
    const{em,bg}=catIcon(t.category||'');
    const vUrl=t.venue_id?`https://foursquare.com/v/${t.venue_id}`:'';
    const tUrl=t.id?`https://foursquare.com/item/${t.id}`:'';
    const f=t.nc?flagHtml(t.nc):'';
    const loc=[t.nci||t.city,t.nc||t.country].filter(Boolean).join(', ');
    const agree=t.agree_count>0?`<span class="tc-agree">👍 ${t.agree_count}</span>`:'';
    const closedBadge=t.closed?'<span class="tc-closed">CLOSED</span>':'';
    const venueLabel=vUrl?`<a href="${vUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(t.venue||'Unknown venue')}</a>`:esc(t.venue||'Unknown venue');
    return `<div class="tcard" id="tc_${i}" onclick="selectTip(${i})">
      <div class="tc-venue-row">
        <div class="tc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
        <div class="tc-venue">${venueLabel}${closedBadge}</div>
      </div>
      <div class="tc-text">${esc(t.text||'')}</div>
      <div class="tc-meta">
        <span class="tc-cat">${esc(t.category||'')}</span>
        <span class="tc-loc">${f}${esc(loc)}</span>
        ${agree}
      </div>
      <div class="tc-foot">
        <span class="tc-date">${t.date}</span>
        ${tUrl?`<a class="tc-fsq" href="${tUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">↗ foursquare</a>`:''}
      </div>
    </div>`;
  }).join('');
}

function selectTip(i){
  if(selMarker)selMarker.setStyle({radius:6,weight:1});
  document.querySelectorAll('.tcard.sel').forEach(el=>el.classList.remove('sel'));
  const el=document.getElementById('tc_'+i);
  if(el){el.classList.add('sel');el.scrollIntoView({block:'nearest',behavior:'smooth'});}
  if(markers[i]){
    markers[i].setStyle({radius:10,weight:2});
    selMarker=markers[i];
    map.panTo([ALL[i].lat,ALL[i].lng],{animate:true});
    markers[i].openPopup();
  }
}

function jumpLatest(){document.getElementById('feedScroll').scrollTo({top:0,behavior:'smooth'});}
function jumpOldest(){const s=document.getElementById('feedScroll');s.scrollTo({top:s.scrollHeight,behavior:'smooth'});}
function onSearch(v){query=v;render();}
function sortBy(mode,el){
  sortMode=mode;
  document.querySelectorAll('.sbtn').forEach(b=>b.classList.remove('act'));
  el.classList.add('act');
  render();
}

buildCtryTabs();
render();
</script>
