<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Tips · Foursquare Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600&family=DM+Mono&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/6.6.6/css/flag-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;}
.page{display:flex;flex-direction:column;height:100vh;}

/* ── Top bar ── */
.topbar{display:flex;align-items:center;gap:8px;padding:8px 16px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;z-index:200;flex-wrap:wrap;min-height:48px;}
.topbar h1{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:900;background:linear-gradient(130deg,#f5d48a,#e8b86d 50%,#b97c30);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;padding:.05em 0 .12em;display:inline-block;white-space:nowrap;}
.back-link{color:var(--gold);text-decoration:none;font-size:.72rem;font-weight:600;opacity:.8;white-space:nowrap;}
.back-link:hover{opacity:1;}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;}
.srch{background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:5px 10px;color:var(--text);font-size:.73rem;outline:none;width:185px;}
.srch:focus{border-color:var(--gold);}
.badge{font-size:.63rem;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap;}
.sbtn{background:var(--card2);border:1px solid var(--border);border-radius:7px;color:var(--muted);padding:4px 9px;cursor:pointer;font-size:.70rem;transition:all .12s;font-family:'DM Sans',sans-serif;}
.sbtn:hover{border-color:var(--gold);color:var(--gold);}
.sbtn.act{border-color:var(--gold);color:var(--gold);background:rgba(232,184,109,.08);}
.nav-btn{background:var(--card2);border:1px solid var(--border);border-radius:7px;color:var(--muted);padding:4px 9px;cursor:pointer;font-size:.70rem;transition:all .12s;white-space:nowrap;font-family:'DM Sans',sans-serif;}
.nav-btn:hover{border-color:var(--gold);color:var(--gold);}

/* ── Tab bars ── */
.tabs-wrap{display:flex;align-items:center;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;}
.tabs-arrow{background:transparent;border:none;color:var(--muted);padding:0 6px;cursor:pointer;font-size:.8rem;flex-shrink:0;line-height:28px;transition:color .12s;}
.tabs-arrow:hover{color:var(--gold);}
.tabs-row{display:flex;align-items:center;gap:4px;padding:4px 2px;flex:1;overflow-x:auto;flex-wrap:nowrap;scrollbar-width:none;}
.tabs-row::-webkit-scrollbar{display:none;}
.tab-btn{background:transparent;border:1px solid transparent;border-radius:6px;color:var(--muted);padding:3px 9px;cursor:pointer;font-size:.68rem;white-space:nowrap;font-family:'DM Sans',sans-serif;transition:all .12s;flex-shrink:0;}
.tab-btn:hover{border-color:var(--border);color:var(--text);}
.tab-btn.act{border-color:var(--gold);color:var(--gold);background:rgba(232,184,109,.08);}
.tab-count{font-family:'DM Mono',monospace;font-size:.60rem;opacity:.55;}
.cities-wrap{display:none;}
.cities-wrap.vis{display:flex;}

/* ── Layout ── */
.content{display:flex;flex:1;overflow:hidden;}
.feed-col{width:420px;flex-shrink:0;overflow:hidden;display:flex;flex-direction:column;border-right:1px solid var(--border);}
.feed-scroll{flex:1;overflow-y:auto;padding:8px;}
.feed-scroll::-webkit-scrollbar{width:3px;}
.feed-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.map-col{flex:1;position:relative;min-width:0;}
#map{position:absolute;inset:0;}
.leaflet-container{background:#0c0e14;}

/* ── Tip card ── */
.tcard{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:13px 16px 11px;margin-bottom:8px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden;}
.tcard::after{content:'';position:absolute;top:0;left:16px;right:16px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.25;}
.tcard:hover{border-color:rgba(232,184,109,.35);}
.tcard.sel{border-color:var(--gold);}
.tc-venue-row{display:flex;align-items:flex-start;gap:7px;margin-bottom:7px;}
.tc-cat-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.tc-venue{font-size:.86rem;font-weight:700;line-height:1.28;flex:1;}
.tc-venue a{color:var(--text);text-decoration:none;}
.tc-venue a:hover{color:var(--gold);}
.tc-text{font-size:.83rem;color:var(--text);line-height:1.55;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden;}
.tc-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:5px;}
.tc-cat{font-family:'DM Mono',monospace;font-size:.56rem;text-transform:uppercase;letter-spacing:.06em;color:var(--teal);white-space:nowrap;}
.tc-loc{font-size:.70rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.tc-agree{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--gold);white-space:nowrap;}
.tc-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.tc-date{font-family:'DM Mono',monospace;font-size:.60rem;color:var(--muted);}
.tc-fsq{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--muted);text-decoration:none;}
.tc-fsq:hover{color:var(--gold);}
.tc-closed{font-family:'DM Mono',monospace;font-size:.50rem;color:#ef4444;border:1px solid rgba(239,68,68,.45);border-radius:3px;padding:1px 4px;margin-left:5px;vertical-align:middle;white-space:nowrap;line-height:1.4;}
.tc-loc{display:inline-flex;align-items:center;gap:3px;}

/* ── Map popup ── */
.leaflet-popup-content-wrapper{background:var(--card2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.80rem;}
.leaflet-popup-tip{background:var(--card2);}
.leaflet-popup-content{margin:10px 14px;}

@media(max-width:700px){.feed-col{width:100%;border-right:none;}.map-col{display:none;}}
</style>
</head>
<body>
<div class="page">
  <div class="topbar">
    <a class="back-link" href="index.html">← Journal</a>
    <h1>Tips</h1>
    <button class="sbtn act" id="sDate" onclick="sortBy('date',this)">By Date</button>
    <button class="sbtn" id="sAgree" onclick="sortBy('agree',this)">👍 By Agree</button>
    <button class="nav-btn" onclick="jumpLatest()">↑ Latest</button>
    <button class="nav-btn" onclick="jumpOldest()">↓ Oldest</button>
    <div class="tb-right">
      <input class="srch" id="srch" type="text" placeholder="Search tips, venues, cities…" oninput="onSearch(this.value)">
      <span class="badge" id="badge"></span>
    </div>
  </div>
  <div class="tabs-wrap" id="ctryWrap">
    <button class="tabs-arrow" onclick="scrollTabs('ctryTabs',-160)">◀</button>
    <div class="tabs-row" id="ctryTabs"></div>
    <button class="tabs-arrow" onclick="scrollTabs('ctryTabs',160)">▶</button>
  </div>
  <div class="tabs-wrap cities-wrap" id="cityWrap">
    <button class="tabs-arrow" onclick="scrollTabs('cityTabs',-160)">◀</button>
    <div class="tabs-row" id="cityTabs"></div>
    <button class="tabs-arrow" onclick="scrollTabs('cityTabs',160)">▶</button>
  </div>
  <div class="content">
    <div class="feed-col">
      <div class="feed-scroll" id="feedScroll"></div>
    </div>
    <div class="map-col">
      <div id="map"></div>
    </div>
  </div>
</div>

