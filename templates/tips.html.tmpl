<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Tips · Foursquare Dashboard</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@900&family=DM+Sans:wght@400;600&family=DM+Mono&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/flag-icon-css/6.6.6/css/flag-icons.min.css">
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<style>
:root{--bg:#0c0e14;--card:#12141c;--card2:#181a24;--border:#222738;--text:#e0e2ec;--muted:#6b7280;--gold:#e8b86d;--teal:#4ec9b0;}
*{box-sizing:border-box;margin:0;padding:0;}
html,body{height:100%;overflow:hidden;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;}
.page{display:flex;flex-direction:column;height:100vh;}

/* ── Top bar ── */
.topbar{display:flex;align-items:center;gap:8px;padding:8px 16px;border-bottom:1px solid var(--border);background:var(--card);flex-shrink:0;z-index:200;flex-wrap:wrap;min-height:48px;}
.topbar h1{font-family:'Playfair Display',serif;font-size:1.2rem;font-weight:900;background:linear-gradient(130deg,#f5d48a,#e8b86d 50%,#b97c30);-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;padding:.05em 0 .12em;display:inline-block;white-space:nowrap;}
.back-link{color:var(--gold);text-decoration:none;font-size:.72rem;font-weight:600;opacity:.8;white-space:nowrap;}
.back-link:hover{opacity:1;}
.tb-right{margin-left:auto;display:flex;align-items:center;gap:8px;}
.srch{background:var(--card2);border:1px solid var(--border);border-radius:7px;padding:5px 10px;color:var(--text);font-size:.73rem;outline:none;width:185px;}
.srch:focus{border-color:var(--gold);}
.badge{font-size:.63rem;color:var(--muted);font-family:'DM Mono',monospace;white-space:nowrap;}
.sbtn{background:var(--card2);border:1px solid var(--border);border-radius:7px;color:var(--muted);padding:4px 9px;cursor:pointer;font-size:.70rem;transition:all .12s;font-family:'DM Sans',sans-serif;}
.sbtn:hover{border-color:var(--gold);color:var(--gold);}
.sbtn.act{border-color:var(--gold);color:var(--gold);background:rgba(232,184,109,.08);}

/* ── Layout ── */
.content{display:flex;flex:1;overflow:hidden;}
.feed-col{width:420px;flex-shrink:0;overflow:hidden;display:flex;flex-direction:column;border-right:1px solid var(--border);}
.feed-scroll{flex:1;overflow-y:auto;padding:8px;}
.feed-scroll::-webkit-scrollbar{width:3px;}
.feed-scroll::-webkit-scrollbar-thumb{background:rgba(255,255,255,.08);border-radius:2px;}
.map-col{flex:1;position:relative;min-width:0;}
#map{position:absolute;inset:0;}
.leaflet-container{background:#0c0e14;}

/* ── Tip card ── */
.tcard{background:var(--card);border:1px solid var(--border);border-radius:11px;padding:13px 16px 11px;margin-bottom:8px;cursor:pointer;transition:border-color .15s;position:relative;overflow:hidden;}
.tcard::after{content:'';position:absolute;top:0;left:16px;right:16px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);opacity:.25;}
.tcard:hover{border-color:rgba(232,184,109,.35);}
.tcard.sel{border-color:var(--gold);}
.tc-venue-row{display:flex;align-items:flex-start;gap:7px;margin-bottom:7px;}
.tc-cat-icon{width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;flex-shrink:0;}
.tc-venue{font-size:.86rem;font-weight:700;line-height:1.28;flex:1;}
.tc-venue a{color:var(--text);text-decoration:none;}
.tc-venue a:hover{color:var(--gold);}
.tc-text{font-size:.83rem;color:var(--text);line-height:1.55;margin-bottom:8px;display:-webkit-box;-webkit-line-clamp:4;-webkit-box-orient:vertical;overflow:hidden;}
.tc-meta{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin-bottom:5px;}
.tc-cat{font-family:'DM Mono',monospace;font-size:.56rem;text-transform:uppercase;letter-spacing:.06em;color:var(--teal);white-space:nowrap;}
.tc-loc{font-size:.70rem;color:var(--muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1;}
.tc-agree{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--gold);white-space:nowrap;}
.tc-foot{display:flex;align-items:center;justify-content:space-between;gap:8px;}
.tc-date{font-family:'DM Mono',monospace;font-size:.60rem;color:var(--muted);}
.tc-fsq{font-family:'DM Mono',monospace;font-size:.58rem;color:var(--muted);text-decoration:none;}
.tc-fsq:hover{color:var(--gold);}

/* ── Map popup ── */
.leaflet-popup-content-wrapper{background:var(--card2);border:1px solid var(--border);border-radius:8px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.80rem;}
.leaflet-popup-tip{background:var(--card2);}
.leaflet-popup-content{margin:10px 14px;}

@media(max-width:700px){.feed-col{width:100%;border-right:none;}.map-col{display:none;}}
</style>
</head>
<body>
<div class="page">
  <div class="topbar">
    <a class="back-link" href="index.html">← Journal</a>
    <h1>Tips</h1>
    <button class="sbtn act" id="sDate" onclick="sortBy('date',this)">By Date</button>
    <button class="sbtn" id="sAgree" onclick="sortBy('agree',this)">👍 By Agree</button>
    <div class="tb-right">
      <input class="srch" id="srch" type="text" placeholder="Search tips, venues, cities…" oninput="onSearch(this.value)">
      <span class="badge" id="badge"></span>
    </div>
  </div>
  <div class="content">
    <div class="feed-col">
      <div class="feed-scroll" id="feedScroll"></div>
    </div>
    <div class="map-col">
      <div id="map"></div>
    </div>
  </div>
</div>

<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
const ALL = TIPS_DATA_PLACEHOLDER;

const CTRY_CODE = {"Belarus":"by","Moldova":"md","Poland":"pl","Russia":"ru","Ukraine":"ua","Germany":"de","France":"fr","Italy":"it","Spain":"es","Turkey":"tr","Türkiye":"tr","Sweden":"se","Denmark":"dk","Norway":"no","Finland":"fi","Austria":"at","Switzerland":"ch","Netherlands":"nl","Belgium":"be","Portugal":"pt","Czech Republic":"cz","Czechia":"cz","Hungary":"hu","Slovakia":"sk","Romania":"ro","Bulgaria":"bg","Croatia":"hr","Slovenia":"si","Serbia":"rs","Bosnia and Herzegovina":"ba","Montenegro":"me","North Macedonia":"mk","Albania":"al","Kosovo":"xk","Estonia":"ee","Latvia":"lv","Lithuania":"lt","Greece":"gr","Cyprus":"cy","Malta":"mt","Iceland":"is","Ireland":"ie","United Kingdom":"gb","Georgia":"ge","Armenia":"am","Azerbaijan":"az","Kazakhstan":"kz","Uzbekistan":"uz","Kyrgyzstan":"kg","Tajikistan":"tj","Turkmenistan":"tm","Mongolia":"mn","China":"cn","Japan":"jp","South Korea":"kr","Taiwan":"tw","India":"in","Thailand":"th","Vietnam":"vn","Indonesia":"id","Singapore":"sg","Malaysia":"my","Pakistan":"pk","Nepal":"np","Qatar":"qa","UAE":"ae","United Arab Emirates":"ae","Saudi Arabia":"sa","Jordan":"jo","Israel":"il","Iraq":"iq","Lebanon":"lb","Iran":"ir","Egypt":"eg","Morocco":"ma","Tunisia":"tn","South Africa":"za","United States":"us","Canada":"ca","Mexico":"mx","Brazil":"br","Argentina":"ar","Chile":"cl","Colombia":"co","Peru":"pe","Australia":"au","New Zealand":"nz","Holy See (Vatican City State)":"va","San Marino":"sm","Monaco":"mc"};

function flagHtml(c){const code=(CTRY_CODE[c]||'').toLowerCase();return code?`<span class="fi fi-${code}" style="border-radius:2px;font-size:.85em;vertical-align:middle;"></span> `:''}
const esc=s=>(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

const CAT_ICON={"Restaurant":["🍽️","#e88c6d"],"Café":["☕","#c49a6c"],"Coffee Shop":["☕","#c49a6c"],"Bar":["🍺","#6d9de8"],"Pub":["🍺","#6d9de8"],"Nightclub":["🎵","#9b6de8"],"Park":["🌿","#4ead68"],"Garden":["🌸","#d48c6d"],"Hotel":["🏨","#6db8e8"],"Hostel":["🏨","#6db8e8"],"Museum":["🏛️","#e8c86d"],"Art Gallery":["🎨","#e86d9b"],"Theater":["🎭","#e86d9b"],"Train Station":["🚆","#6de8d4"],"Airport":["✈️","#6db8e8"],"Bus Station":["🚌","#6db8e8"],"Supermarket":["🛒","#6de8a2"],"Shopping Mall":["🛍️","#e86d9b"],"Pharmacy":["💊","#6de8d4"],"Gym":["💪","#e8a46d"],"Beach":["🏖️","#e8c86d"],"Lake":["💧","#6db8e8"],"Mountain":["⛰️","#8a8a8a"],"Bakery":["🥐","#e8c86d"],"Bookstore":["📚","#6db8e8"],"University":["🎓","#e8c86d"]};

function catIcon(cat){
  const lower=(cat||'').toLowerCase();
  for(const[k,[em,bg]]of Object.entries(CAT_ICON)){if(lower.includes(k.toLowerCase()))return{em,bg};}
  return{em:'📍',bg:'#4a5270'};
}

// ── Map ──────────────────────────────────────────────────────────────────────
const map=L.map('map',{preferCanvas:true}).setView([30,15],2);
L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'&copy; OpenStreetMap &copy; CARTO',subdomains:'abcd',maxZoom:19}).addTo(map);

const markers={};
let selMarker=null;
ALL.forEach((t,i)=>{
  if(t.lat==null||t.lng==null)return;
  const{em,bg}=catIcon(t.category||'');
  const m=L.circleMarker([t.lat,t.lng],{radius:6,fillColor:bg,fillOpacity:.75,color:bg,weight:1}).addTo(map);
  const tipPreview=esc((t.text||'').slice(0,90))+(t.text&&t.text.length>90?'…':'');
  m.bindPopup(`<b>${esc(t.venue||'')}</b><br><span style="font-size:.75rem;color:#9ca3af;">${esc(t.city||'')}${t.country?', '+esc(t.country):''}</span><br><br><i style="font-size:.78rem;">"${tipPreview}"</i>`,{maxWidth:220});
  markers[i]=m;
});

// ── Filter & sort ────────────────────────────────────────────────────────────
let sortMode='date', query='';

function getFiltered(){
  const q=query.toLowerCase();
  return ALL.map((_,i)=>i).filter(i=>{
    if(!q)return true;
    const t=ALL[i];
    return (t.text||'').toLowerCase().includes(q)||(t.venue||'').toLowerCase().includes(q)||(t.city||'').toLowerCase().includes(q)||(t.country||'').toLowerCase().includes(q)||(t.category||'').toLowerCase().includes(q);
  });
}

function render(){
  let idx=getFiltered();
  if(sortMode==='agree')idx.sort((a,b)=>(ALL[b].agree_count||0)-(ALL[a].agree_count||0));
  document.getElementById('badge').textContent=idx.length+' / '+ALL.length+' tips';
  document.getElementById('feedScroll').innerHTML=idx.map(i=>{
    const t=ALL[i];
    const{em,bg}=catIcon(t.category||'');
    const vUrl=t.venue_id?`https://foursquare.com/v/${t.venue_id}`:'';
    const tUrl=t.id?`https://foursquare.com/item/${t.id}`:'';
    const f=t.country?flagHtml(t.country):'';
    const loc=[t.city,t.country].filter(Boolean).join(', ');
    const agree=t.agree_count>0?`<span class="tc-agree">👍 ${t.agree_count}</span>`:'';
    return `<div class="tcard" id="tc_${i}" onclick="selectTip(${i})">
      <div class="tc-venue-row">
        <div class="tc-cat-icon" style="background:${bg}22;border:1px solid ${bg}55">${em}</div>
        <div class="tc-venue">${vUrl?`<a href="${vUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">${esc(t.venue||'Unknown venue')}</a>`:esc(t.venue||'Unknown venue')}</div>
      </div>
      <div class="tc-text">${esc(t.text||'')}</div>
      <div class="tc-meta">
        <span class="tc-cat">${esc(t.category||'')}</span>
        <span class="tc-loc">${f}${esc(loc)}</span>
        ${agree}
      </div>
      <div class="tc-foot">
        <span class="tc-date">${t.date}</span>
        ${tUrl?`<a class="tc-fsq" href="${tUrl}" target="_blank" rel="noopener" onclick="event.stopPropagation()">↗ foursquare</a>`:''}
      </div>
    </div>`;
  }).join('');
}

function selectTip(i){
  if(selMarker)selMarker.setStyle({radius:6,weight:1});
  document.querySelectorAll('.tcard.sel').forEach(el=>el.classList.remove('sel'));
  const el=document.getElementById('tc_'+i);
  if(el){el.classList.add('sel');el.scrollIntoView({block:'nearest',behavior:'smooth'});}
  if(markers[i]){
    markers[i].setStyle({radius:10,weight:2});
    selMarker=markers[i];
    map.panTo([ALL[i].lat,ALL[i].lng],{animate:true});
    markers[i].openPopup();
  }
}

function onSearch(v){query=v;render();}
function sortBy(mode,el){
  sortMode=mode;
  document.querySelectorAll('.sbtn').forEach(b=>b.classList.remove('act'));
  el.classList.add('act');
  render();
}

render();
</script>
</body>
</html>
